<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hari Enterprises | Excellence & Innovation</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 scroll-smooth">

    <!-- Navigation -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="text-2xl font-bold tracking-tight text-slate-900">
                HARI<span class="text-blue-600">ENTERPRISES</span>
            </div>
            <nav class="hidden md:flex space-x-8 font-medium text-slate-600">
                <a href="#home" class="hover:text-blue-600 transition">Home</a>
                <a href="#about" class="hover:text-blue-600 transition">About Us</a>
                <a href="#services" class="hover:text-blue-600 transition">Services</a>
                <a href="#contact" class="hover:text-blue-600 transition">Contact</a>
            </nav>
            <a href="#contact" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg font-medium transition shadow-sm hidden md:inline-block">
                Get a Quote
            </a>
        </div>
    </header>

    <!-- Hero Section -->
    <section id="home" class="relative py-24 md:py-32 overflow-hidden bg-gradient-to-b from-blue-50/50 to-transparent">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
            <div class="space-y-6">
                <div class="inline-flex items-center gap-2 bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-sm font-medium">
                    <span class="w-2 h-2 rounded-full bg-blue-600 animate-pulse"></span>
                    Driving Industry Standards Forward
                </div>
                <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-slate-950 leading-tight">
                    Reliable Solutions for Global Businesses.
                </h1>
                <p class="text-lg text-slate-600 leading-relaxed max-w-xl">
                    At Hari Enterprises, we bridge the gap between complexity and efficiency. Delivering top-tier wholesale operations, distribution, and corporate enterprise solutions tailored to your scale.
                </p>
                <div class="flex flex-wrap gap-4 pt-2">
                    <a href="#services" class="bg-slate-900 hover:bg-slate-800 text-white px-6 py-3 rounded-lg font-semibold transition">
                        Explore Services
                    </a>
                    <a href="#about" class="border border-slate-300 hover:border-slate-400 bg-white text-slate-700 px-6 py-3 rounded-lg font-semibold transition">
                        Learn More
                    </a>
                </div>
            </div>
            <div class="relative flex justify-center">
                <!-- Clean Abstract Visual Placeholder -->
                <div class="w-full max-w-md h-80 md:h-96 bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl shadow-xl flex items-center justify-center text-white p-8 overflow-hidden relative">
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(255,255,255,0.1),transparent)]"></div>
                    <div class="text-center z-10">
                        <p class="text-5xl font-bold mb-2">100%</p>
                        <p class="text-blue-100 uppercase tracking-wider text-sm font-medium">Commitment to Quality</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <hr class="border-slate-100 max-w-7xl mx-auto">

    <!-- About Section -->
    <section id="about" class="py-24 max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-12">
            <div>
                <h2 class="text-xs font-bold uppercase tracking-widest text-blue-600 mb-3">Who We Are</h2>
                <p class="text-3xl font-bold text-slate-950">Built on trust, legacy, and performance.</p>
            </div>
            <div class="md:col-span-2 space-y-6 text-lg text-slate-600 leading-relaxed">
                <p>
                    Founded with a vision to deliver unparalleled operational excellence, Hari Enterprises has grown into a trusted B2B partner. We support diverse industry vectors through robust supply chains, transparent asset management, and client-first consulting.
                </p>
                <p>
                    Our core mission is straightforward: to streamline your logistics, optimize your procurement pipelines, and provide premium quality solutions that help your business scale safely and sustainably.
                </p>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="py-24 bg-slate-900 text-white">
        <div class="max-w-7xl mx-auto px-6">
            <div class="max-w-2xl mb-16">
                <h2 class="text-xs font-bold uppercase tracking-widest text-blue-400 mb-3">Our Offerings</h2>
                <p class="text-3xl md:text-4xl font-bold">Comprehensive solutions designed for modern markets.</p>
            </div>
            
            <div class="grid md:grid-cols-3 gap-8">
                <!-- Service 1 -->
                <div class="bg-slate-800 p-8 rounded-xl border border-slate-700/50 hover:border-blue-500/50 transition group">
                    <div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400 mb-6 group-hover:bg-blue-500 group-hover:text-white transition-all duration-300">
                        📦
                    </div>
                    <h3 class="text-xl font-bold mb-3">Enterprise Distribution</h3>
                    <p class="text-slate-400 leading-relaxed">End-to-end management, sourcing, and wholesale supply chains designed to minimize downtime and maximize throughput.</p>
                </div>
                <!-- Service 2 -->
                <div class="bg-slate-800 p-8 rounded-xl border border-slate-700/50 hover:border-blue-500/50 transition group">
                    <div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400 mb-6 group-hover:bg-blue-500 group-hover:text-white transition-all duration-300">
                        ⚡
                    </div>
                    <h3 class="text-xl font-bold mb-3">B2B Procurement</h3>
                    <p class="text-slate-400 leading-relaxed">Strategic product sourcing, multi-vendor coordination, and high-volume order fulfillments customized to your specifications.</p>
                </div>
                <!-- Service 3 -->
                <div class="bg-slate-800 p-8 rounded-xl border border-slate-700/50 hover:border-blue-500/50 transition group">
                    <div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400 mb-6 group-hover:bg-blue-500 group-hover:text-white transition-all duration-300">
                        🛡️
                    </div>
                    <h3 class="text-xl font-bold mb-3">Quality Assurance</h3>
                    <p class="text-slate-400 leading-relaxed">Strict quality control measures tracking every batch and asset to meet strict regulatory and compliance benchmarks.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-24 max-w-7xl mx-auto px-6">
        <div class="bg-gradient-to-br from-slate-50 to-blue-50/30 border border-slate-200/60 rounded-2xl p-8 md:p-16 grid md:grid-cols-2 gap-12 items-center">
            <div class="space-y-6">
                <h2 class="text-3xl font-bold text-slate-950 tracking-tight">Let's build a partnership.</h2>
                <p class="text-slate-600 leading-relaxed">
                    Have an inquiry or looking to scale your current distribution infrastructure? Drop us a line, and our specialized team will get back to you within one business day.
                </p>
                <div class="space-y-3 pt-2 text-slate-700 font-medium">
                    <div class="flex items-center gap-3">
                        <span class="text-blue-600">📍</span> India Corporate Hub
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="text-blue-600">✉️</span> contact@harienterprises.com
                    </div>
                </div>
            </div>
            
            <!-- Contact Form -->
            <form class="space-y-4" onsubmit="event.preventDefault(); alert('Message sent successfully!');">
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-2">Company Name</label>
                    <input type="text" placeholder="Hari Enterprises" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:outline-none focus:border-blue-500 transition bg-white" required>
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-2">Email Address</label>
                    <input type="email" placeholder="you@company.com" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:outline-none focus:border-blue-500 transition bg-white" required>
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-2">How can we help?</label>
                    <textarea rows="4" placeholder="Tell us about your requirements..." class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:outline-none focus:border-blue-500 transition bg-white" required></textarea>
                </div>
                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition shadow-sm">
                    Submit Inquiry
                </button>
            </form>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-100 py-8">
        <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between text-sm text-slate-500 gap-4">
            <div>
                © 2026 Hari Enterprises. All rights reserved.
            </div>
            <div class="flex space-x-6">
                <a href="#" class="hover:text-slate-800">Privacy Policy</a>
                <a href="#" class="hover:text-slate-800">Terms of Service</a>
            </div>
        </div>
    </footer>

</body>
</html>
